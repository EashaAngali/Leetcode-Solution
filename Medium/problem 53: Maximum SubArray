class Solution {
    public int maxSubArray(int[] nums) {
         int currSum=0;
         int MaxSum=Integer.MIN_VALUE;
        for(int val:nums){
           currSum+=val;
           if(MaxSum<currSum){
            MaxSum=currSum;
           }
           if(currSum<0){
            currSum=0;
           }

        }
        return MaxSum;
    }
}
