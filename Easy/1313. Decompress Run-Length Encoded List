class Solution {
    public int[] decompressRLElist(int[] nums) {
      int len = 0;
    int n = nums.length;
    for (int i = 0; i < n; i += 2) {
      len += nums[i];
    }
    int k=0;
    int[] result=new int[len];
        for(int i=0;i<nums.length;i+=2){
            int freq=nums[i];
            int val=nums[i+1];
            for(int j=0;j<freq;j++){
                result[k++]=val;
                
            }
        }
        return result;
    }
}
